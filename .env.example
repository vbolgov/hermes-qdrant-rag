# Local Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=consulting_kb
RAG_DATA_DIR=./library
RAG_MANIFEST=./Context/rag-index-manifest.csv

# Default on macOS Apple Silicon. The model is downloaded during bootstrap.
EMBEDDING_BACKEND=mlx
MLX_EMBED_MODEL=mlx-community/multilingual-e5-small-mlx

# Alternative local backend.
LOCAL_EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Used only when EMBEDDING_BACKEND=openai.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_API_KEY=

# Used only after explicit OCR approval for scanned PDFs.
OCR_LANGUAGE=ru
